# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
APP_ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mktg_platform

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Encryption (AES-256 key for storing platform tokens) ──────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_FERNET

# ─── Claude AI ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Meta (Facebook) Ads ───────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v1/oauth/meta/callback

# ─── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback
GOOGLE_DEVELOPER_TOKEN=

# ─── TikTok Ads ────────────────────────────────────────────────────────────────
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v1/oauth/tiktok/callback

# ─── DV360 (Display & Video 360) ───────────────────────────────────────────────
DV360_CLIENT_ID=
DV360_CLIENT_SECRET=
DV360_REDIRECT_URI=http://localhost:8000/api/v1/oauth/dv360/callback

# ─── Salesforce Marketing Cloud ────────────────────────────────────────────────
SFMC_CLIENT_ID=
SFMC_CLIENT_SECRET=
SFMC_SUBDOMAIN=
SFMC_ACCOUNT_ID=
